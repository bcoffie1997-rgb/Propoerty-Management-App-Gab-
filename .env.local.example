# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SINGLE_USER_MODE=0
# Preferred env names for single-user mode
OWNER_ID=00000000-0000-0000-0000-000000000000
OWNER_EMAIL=owner@localhost
NEXT_PUBLIC_OWNER_ID=00000000-0000-0000-0000-000000000000
# Backward-compatible aliases (optional)
LOCAL_OWNER_ID=00000000-0000-0000-0000-000000000000
LOCAL_OWNER_EMAIL=owner@localhost
NEXT_PUBLIC_LOCAL_OWNER_ID=00000000-0000-0000-0000-000000000000

# External gate for internet-facing single-user mode
EXTERNAL_GATE_ENABLED=0
EXTERNAL_GATE_USER=admin
EXTERNAL_GATE_PASSWORD=change-me

# PostHog (optional - leave blank initially)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
